Output demo/recordings/actions.gif
Set Shell bash
Set FontFamily "JetBrainsMono Nerd Font Mono"
Set FontSize 13
Set Width 1400
Set Height 800
Set TypingSpeed 80ms
Set Theme "Ayu Mirage"

Hide
Type "./waxon-demo demo"
Enter
Sleep 2s
Show

# Switch to tracklist and select a track
Tab
Sleep 500ms
Type "jjj"
Sleep 500ms

# Open context actions
Type "o"
Sleep 1s

# Navigate the popup
Type "j"
Sleep 400ms
Type "j"
Sleep 400ms

# Close with Escape
Escape
Sleep 1s

Sleep 1s
