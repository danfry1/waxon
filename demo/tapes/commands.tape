Output demo/recordings/commands.gif
Set Shell bash
Set FontFamily "JetBrainsMono Nerd Font Mono"
Set FontSize 13
Set Width 1400
Set Height 800
Set TypingSpeed 80ms
Set Theme "Ayu Mirage"

Hide
Type "./waxon-demo demo"
Enter
Sleep 2s
Show

# Volume command
Type ":vol 80"
Enter
Sleep 1.5s

# Shuffle command
Type ":shuffle"
Enter
Sleep 1.5s

# Repeat command
Type ":repeat track"
Enter
Sleep 1.5s

# Turn repeat off
Type ":repeat off"
Enter
Sleep 1.5s

Sleep 1s
